<!DOCTYPE html>
<html>
<head>
<title>WinPE Deployment Tool</title>
<!-- HTA shell settings: maximize the WinPE UI and remove unsafe chrome/actions. -->
<HTA:APPLICATION
    ID="WinPEDeploymentTool"
    APPLICATIONNAME="WinPEDeploymentTool"
    BORDER="none"
    CAPTION="yes"
    CONTEXTMENU="no"
    WINDOWSTATE="maximize"
    RESIZABLE="no"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
>
<meta http-equiv="X-UA-Compatible" content="IE=9">
<style type="text/css">
html, body {
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
}
body {
    background: #eef2f5;
    color: #18212b;
    font-family: Segoe UI, Arial, sans-serif;
    font-size: 13px;
}
.app {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 10px;
}
/* Main screen layout: top controls, middle progress, bottom detailed logs. */
.top-layer {
    position: absolute;
    top: 10px;
    right: 10px;
    left: 10px;
    height: 300px;
}
/* Keep the progress band fixed so it never jumps while logs refresh. */
.middle-layer {
    position: absolute;
    top: 320px;
    right: 10px;
    left: 10px;
    height: 100px;
}
/* The log layer fills the remaining screen height below the progress band. */
.bottom-layer {
    position: absolute;
    top: 430px;
    right: 10px;
    bottom: 10px;
    left: 10px;
}
.panel {
    background: #ffffff;
    border: 1px solid #bfccd8;
    border-radius: 6px;
    box-sizing: border-box;
    padding: 12px;
}
/* Left panel is for editable deployment inputs only. */
.left-panel {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 49.5%;
}
/* Right panel is for read-only summary, confirmations, and operator actions. */
.right-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 49.5%;
}
.title-row {
    border-bottom: 1px solid #d5dde5;
    margin-bottom: 8px;
    padding-bottom: 6px;
}
h1 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
}
.mode {
    position: absolute;
    right: 28px;
    top: 20px;
    height: 42px;
    line-height: 42px;
    padding: 0 22px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 600;
}
.mode-safe {
    background-color: #e9329d; 
    color: #f7e5f3; 
}
.mode-winpe {
    background-color: #36df76;
    color: #DCFCE7;
}
.subtle {
    color: #53616f;
    margin-top: 3px;
}
.section-title {
    color: #354252;
    font-size: 12px;
    font-weight: 700;
    margin: 8px 0 5px 0;
    text-transform: uppercase;
}
.row {
    margin-bottom: 7px;
}
.pair {
    display: table;
    width: 100%;
    table-layout: fixed;
}
.pair .cell {
    display: table-cell;
    vertical-align: top;
}
.pair .cell:first-child {
    padding-right: 8px;
}
label {
    display: block;
    font-weight: 600;
    margin-bottom: 3px;
}
input.text, select, textarea {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #9dacbc;
    font-family: Segoe UI, Arial, sans-serif;
    font-size: 13px;
}
input.text, select {
    height: 30px;
    padding: 5px;
}
textarea {
    padding: 8px;
    resize: none;
}
.codebox {
    background: #f8fafc;
    color: #17202a;
    font-family: Consolas, Courier New, monospace;
}
.params-box {
    height: 160px;
}
.log-box {
    position: absolute;
    top: 50px;
    right: 10px;
    bottom: 10px;
    left: 10px;
    width: auto;
    height: auto;
}
/* Summary replaces the raw selected_params.ini preview on the main screen. */
.summary {
    border: 1px solid #d5dde5;
    background: #f8fafc;
    padding: 8px;
    margin-bottom: 8px;
}
.summary-row {
    display: table;
    width: 100%;
    table-layout: fixed;
    margin-bottom: 5px;
}
.summary-name {
    display: table-cell;
    width: 145px;
    color: #53616f;
    font-weight: 600;
}
.summary-value {
    display: table-cell;
    font-family: Consolas, Courier New, monospace;
    overflow-wrap: break-word;
    word-wrap: break-word;
}
.checks label {
    font-weight: 400;
    margin: 5px 0;
}
.right-panel .checks {
    border-top: 1px solid #d5dde5;
    margin-top: 10px;
    padding-top: 8px;
}
.right-panel .checks .section-title {
    margin-top: 0;
}
.danger {
    color: #9a3412;
    font-weight: 700;
}
.button-row {
    position: absolute;
    right: 10px;
    bottom: 10px;
    left: 10px;
    text-align: right;
}
button {
    min-width: 108px;
    height: 34px;
    margin-left: 6px;
    padding: 6px 10px;
    border: 1px solid #7d8a98;
    border-radius: 4px;
    background: #e8edf2;
    color: #17202a;
    font-weight: 600;
    cursor: pointer;
}
button.primary {
    background: #155b9f;
    border-color: #124d86;
    color: #ffffff;
}
button:disabled {
    background: #d9e0e7;
    border-color: #bdc7d0;
    color: #7b8793;
    cursor: default;
}
.progress-header {
    display: table;
    width: 100%;
    margin-bottom: 8px;
}
.progress-label {
    display: table-cell;
    font-weight: 700;
}
.progress-percent {
    display: table-cell;
    width: 70px;
    text-align: right;
    font-family: Consolas, Courier New, monospace;
}
.progress-track {
    height: 22px;
    border: 1px solid #9dacbc;
    background: #edf2f7;
    border-radius: 4px;
    overflow: hidden;
}
.progress-fill {
    width: 0%;
    height: 22px;
    background: #1f7fbd;
}
.progress-fill.success {
    background: #237a3b;
}
.progress-fill.failed {
    background: #b42318;
}
#statusBox {
    margin-top: 6px;
    color: #354252;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>
<script language="JScript" type="text/javascript">
var fso = new ActiveXObject("Scripting.FileSystemObject");
var shell = new ActiveXObject("WScript.Shell");
var deployEnv = {};
var isWinPE = false;
var envLoaded = false;
var htaDir = "";
var htaLogPath = "";
var paramsPath = "";
var exitCodePath = "";
var applyDetailPath = "";
var applyLogPath = "";
var diskpartLogPath = "";
var applyStatePath = "";
var applyRcPath = "";
var exitCodeWritten = false;
var deploymentStarted = false;
var applyRunning = false;
var diskInventory = {};
var deployStartTime = null;
var pollTimer = null;
var elapsedTimer = null;
var lastProgress = 0;
var lastLogText = "";
var wimAutoDetected = false;

function byId(id) {
    return document.getElementById(id);
}

function setStatus(message) {
    if (byId("statusBox")) {
        byId("statusBox").innerText = message;
    }
}

function DetectEnvironment() {
    var systemDrive = "";
    var hasWinPEFolder = false;

    try {
        systemDrive = shell.ExpandEnvironmentStrings("%SystemDrive%");
    } catch (e) {
        systemDrive = "";
    }

    try {
        hasWinPEFolder = fso.FolderExists("X:\\Windows\\System32");
    } catch (e) {
        hasWinPEFolder = false;
    }

    isWinPE = (trimText(systemDrive).toUpperCase() == "X:" && hasWinPEFolder);
    return isWinPE;
}

function environmentModeText() {
    return isWinPE ? "Environment: WinPE" : "Environment: Windows Safe Mode";
}

function updateEnvironmentModeInfo() {
    if (byId("modeValue")) {
        byId("modeValue").innerText = environmentModeText();
    }
}

function getHtaDirectory() {
    var path = unescape(location.pathname);
    path = path.replace(/\//g, "\\");
    if (path.charAt(0) == "\\" && path.charAt(2) == ":") {
        path = path.substring(1);
    }
    return fso.GetParentFolderName(path);
}

function trimText(value) {
    if (value === null || value === undefined) {
        return "";
    }
    return String(value).replace(/^\s+|\s+$/g, "");
}

function combinePath(left, right) {
    if (!left) {
        return right;
    }
    if (left.charAt(left.length - 1) == "\\") {
        return left + right;
    }
    return left + "\\" + right;
}

function ensureFolder(path) {
    if (!path || fso.FolderExists(path)) {
        return;
    }
    var parent = fso.GetParentFolderName(path);
    if (parent && parent != path && !fso.FolderExists(parent)) {
        ensureFolder(parent);
    }
    if (!fso.FolderExists(path)) {
        fso.CreateFolder(path);
    }
}

function writeTextFile(path, text) {
    var file = fso.CreateTextFile(path, true);
    file.Write(text);
    file.Close();
}

function appendTextFile(path, text) {
    var file = fso.OpenTextFile(path, 8, true);
    file.Write(text);
    file.Close();
}

function readTextFile(path) {
    if (!fso.FileExists(path)) {
        return "";
    }
    var file = fso.OpenTextFile(path, 1, false);
    var text = file.ReadAll();
    file.Close();
    return text;
}

function readTail(path, maxChars) {
    var text = readTextFile(path);
    if (text.length > maxChars) {
        return "... log truncated to last " + maxChars + " characters ...\r\n" + text.substring(text.length - maxChars);
    }
    return text;
}

function deleteFileIfExists(path) {
    try {
        if (path && fso.FileExists(path)) {
            fso.DeleteFile(path, true);
        }
    } catch (e) {
    }
}

function nowText() {
    var d = new Date();
    function pad(v) {
        return (v < 10 ? "0" : "") + v;
    }
    return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate()) +
        " " + pad(d.getHours()) + ":" + pad(d.getMinutes()) + ":" + pad(d.getSeconds());
}

function logMessage(message) {
    var line = nowText() + " " + message + "\r\n";
    try {
        if (htaLogPath) {
            appendTextFile(htaLogPath, line);
        }
        if (deployEnv.SESSION_LOG) {
            appendTextFile(deployEnv.SESSION_LOG, "[10] " + line);
        }
    } catch (e) {
    }
}

function parseEnvLine(line) {
    var text = trimText(line);
    var match = /^set\s+"([^=]+)=(.*)"$/i.exec(text);
    if (match) {
        deployEnv[match[1].toUpperCase()] = match[2];
    }
}

function readEnvFile(path) {
    if (!fso.FileExists(path)) {
        return false;
    }
    var file = fso.OpenTextFile(path, 1, false);
    while (!file.AtEndOfStream) {
        parseEnvLine(file.ReadLine());
    }
    file.Close();
    return true;
}

function inferFallbackEnv() {
    var tempRoot = shell.ExpandEnvironmentStrings("%TEMP%");
    deployEnv.WORKDIR = htaDir;
    deployEnv.LOGDIR = combinePath(tempRoot, "AutoApply\\LOG\\UNKNOWN_HTA_ENV");
}

function preparePaths() {
    var htaDetail = combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta");
    applyDetailPath = combinePath(combinePath(deployEnv.LOGDIR, "details"), "20_applyimage");
    htaLogPath = combinePath(htaDetail, "deploy_hta.log");
    paramsPath = combinePath(htaDetail, "selected_params.ini");
    exitCodePath = combinePath(htaDetail, "hta_exit_code.txt");
    applyLogPath = combinePath(applyDetailPath, "applyimage.log");
    diskpartLogPath = combinePath(applyDetailPath, "diskpart.log");
    applyStatePath = combinePath(applyDetailPath, "applyimage.state.ini");
    applyRcPath = combinePath(applyDetailPath, "applyimage.returncode.txt");
}

function setEnvironmentInfo() {
    if (byId("runIdValue")) {
        byId("runIdValue").innerText = deployEnv.RUNID ? deployEnv.RUNID : "(not loaded)";
    }
    if (byId("logDirValue")) {
        byId("logDirValue").innerText = deployEnv.LOGDIR ? deployEnv.LOGDIR : "(not loaded)";
    }
}

function readDeployEnv() {
    htaDir = getHtaDirectory();
    var envPath = combinePath(htaDir, "DeployEnv.cmd");
    var currentEnvPath = fso.GetAbsolutePathName("DeployEnv.cmd");
    deployEnv = {};
    setEnvironmentInfo();

    if (!readEnvFile(envPath) && !readEnvFile(currentEnvPath)) {
        inferFallbackEnv();
        preparePaths();
        setEnvironmentInfo();
        return false;
    }

    if (!deployEnv.WORKDIR) {
        deployEnv.WORKDIR = htaDir;
    }
    if (!deployEnv.LOGDIR) {
        inferFallbackEnv();
        preparePaths();
        setEnvironmentInfo();
        return false;
    }
    preparePaths();
    setEnvironmentInfo();
    return true;
}

function writeExitCode(code, forceOverwrite) {
    if (exitCodeWritten && forceOverwrite !== true) {
        return true;
    }
    try {
        if (!exitCodePath) {
            preparePaths();
        }
        ensureFolder(fso.GetParentFolderName(exitCodePath));
        writeTextFile(exitCodePath, String(code) + "\r\n");
        exitCodeWritten = true;
        return true;
    } catch (e) {
        return false;
    }
}

function handleWindowUnload() {
    if (!exitCodeWritten && !deploymentStarted) {
        writeExitCode(10, false);
    }
}

function updateDeployState() {
    var disk = trimText(byId("targetDisk").value);
    var ready = isWinPE &&
        envLoaded &&
        disk != "" &&
        diskInventory[disk] &&
        byId("confirmWim").checked &&
        byId("confirmDisk").checked &&
        byId("confirmRecovery").checked;

    if (deploymentStarted) {
        ready = false;
    }
    byId("deployButton").disabled = !ready;
    byId("cancelButton").disabled = deploymentStarted;
}

function updateSummary() {
    var diskInfo = getSelectedDiskInfo();
    var diskText = diskInfo.number ? diskInfoText(diskInfo) : "(not selected)";
    var wimText = getEffectiveWimPath();
    var recoveryText = trimText(byId("recoverySize").value);

    if (byId("summaryDisk")) {
        byId("summaryDisk").innerText = diskText;
    }
    if (byId("summaryWim")) {
        byId("summaryWim").innerText = wimText ? wimText : "(not selected)";
    }
    if (byId("summaryRecovery")) {
        byId("summaryRecovery").innerText = recoveryText ? recoveryText + " MB" : "(not selected)";
    }
    updateElapsed();
}

function resetConfirmation(confirmId) {
    byId(confirmId).checked = false;
    updateSummary();
    updateDeployState();
}

function updateWimCustomState() {
    byId("customWimPath").disabled = wimAutoDetected || byId("wimPath").value != "__CUSTOM__";
    resetConfirmation("confirmWim");
}

function clearSelect(selectObj) {
    while (selectObj.options.length > 0) {
        selectObj.remove(0);
    }
}

function addOption(selectObj, value, text) {
    var option = document.createElement("option");
    option.value = value;
    option.text = text;
    selectObj.add(option);
    return option;
}

function mappedDriveInstallWimPath(driveName) {
    var root = trimText(driveName);
    if (root == "") {
        return "";
    }
    if (root.charAt(root.length - 1) != "\\") {
        root += "\\";
    }
    return root + "Images\\Install.wim";
}

function setWimAutoDetected(path) {
    var selectObj = byId("wimPath");
    wimAutoDetected = true;
    clearSelect(selectObj);
    addOption(selectObj, path, path);
    selectObj.value = path;
    selectObj.disabled = true;
    byId("customWimPath").value = "";
    byId("customWimPath").disabled = true;
    resetConfirmation("confirmWim");
}

function setWimManualFallback(message) {
    var selectObj = byId("wimPath");
    wimAutoDetected = false;
    clearSelect(selectObj);
    addOption(selectObj, "__CUSTOM__", "Other/custom path");
    selectObj.value = "__CUSTOM__";
    selectObj.disabled = true;
    byId("customWimPath").value = "";
    byId("customWimPath").disabled = false;
    logMessage(message);
    resetConfirmation("confirmWim");
}

function detectMappedInstallWim() {
    var selectObj = byId("wimPath");
    var mappedCount = 0;
    wimAutoDetected = false;
    clearSelect(selectObj);
    addOption(selectObj, "", "Scanning mapped network drives...");
    selectObj.value = "";
    selectObj.disabled = true;
    byId("customWimPath").value = "";
    byId("customWimPath").disabled = true;
    updateSummary();

    try {
        var network = new ActiveXObject("WScript.Network");
        var drives = network.EnumNetworkDrives();
        for (var i = 0; i < drives.Count(); i += 2) {
            var driveName = trimText(drives.Item(i));
            var remotePath = safeText(drives.Item(i + 1));
            var candidate = mappedDriveInstallWimPath(driveName);
            if (candidate == "") {
                continue;
            }
            mappedCount++;
            logMessage("Checking mapped WIM candidate: " + candidate + " from " + remotePath);
            if (fso.FileExists(candidate)) {
                setWimAutoDetected(candidate);
                logMessage("Auto-detected mapped WIM file: " + candidate);
                return true;
            }
        }
    } catch (e) {
        setWimManualFallback("Mapped network drive WIM scan failed: " + e.message + ". Custom WIM path enabled.");
        return false;
    }

    if (mappedCount == 0) {
        setWimManualFallback("No mapped network drives found. Custom WIM path enabled.");
    } else {
        setWimManualFallback("No mapped network drive contains \\Images\\Install.wim. Custom WIM path enabled.");
    }
    return false;
}

function safeText(value) {
    if (value === null || typeof(value) == "undefined") {
        return "";
    }
    return String(value);
}

function bytesToGbText(sizeValue) {
    var bytes = parseFloat(sizeValue);
    if (isNaN(bytes) || bytes <= 0) {
        return "UnknownGB";
    }
    return (Math.round((bytes / 1073741824) * 10) / 10) + "GB";
}

function normalizeInterfaceType(value) {
    var text = trimText(value);
    if (text == "") {
        return "Unknown";
    }
    return text;
}

function getDiskExcludeReason(interfaceType, mediaType, model, pnpDeviceId) {
    var bus = normalizeInterfaceType(interfaceType).toUpperCase();
    var media = trimText(mediaType).toUpperCase();
    var diskModel = trimText(model).toUpperCase();
    var pnp = trimText(pnpDeviceId).toUpperCase();

    if (bus == "USB") {
        return "InterfaceType=USB";
    }
    if (bus == "SD" || bus == "MMC" || bus == "IEEE1394") {
        return "InterfaceType=" + bus;
    }
    if (media.indexOf("REMOVABLE") >= 0) {
        return "MediaType contains REMOVABLE";
    }
    if (pnp.indexOf("USBSTOR") >= 0) {
        return "PNPDeviceID contains USBSTOR";
    }
    if (pnp.indexOf("USB\\") >= 0) {
        return "PNPDeviceID contains USB\\";
    }
    if (diskModel.indexOf("USB DISK") >= 0 || diskModel.indexOf("USB FLASH") >= 0 || diskModel.indexOf("CARD READER") >= 0) {
        return "Model indicates USB/removable media";
    }
    return "";
}

function addDiskOption(index, sizeBytes, model, interfaceType, mediaType, pnpDeviceId) {
    var diskNumber = trimText(index);
    var diskModel = trimText(model) == "" ? "Unknown model" : trimText(model);
    var diskSizeGb = bytesToGbText(sizeBytes);
    var diskInterface = normalizeInterfaceType(interfaceType);
    var diskMedia = trimText(mediaType);
    var diskPnp = trimText(pnpDeviceId);

    logMessage(
        "Win32_DiskDrive raw: Index=" + diskNumber +
        ", Model=" + diskModel +
        ", Size=" + safeText(sizeBytes) +
        ", SizeGB=" + diskSizeGb +
        ", InterfaceType=" + diskInterface +
        ", MediaType=" + diskMedia +
        ", PNPDeviceID=" + diskPnp
    );

    if (diskNumber == "") {
        logMessage("Disk entry excluded: missing Index.");
        return false;
    }

    var excludeReason = getDiskExcludeReason(diskInterface, diskMedia, diskModel, diskPnp);
    if (excludeReason != "") {
        logMessage("Disk " + diskNumber + " excluded: " + excludeReason + ".");
        return false;
    }

    var diskInfo = {
        number: diskNumber,
        sizeGb: diskSizeGb,
        model: diskModel,
        interfaceType: diskInterface,
        mediaType: diskMedia,
        pnpDeviceId: diskPnp
    };
    diskInventory[diskNumber] = diskInfo;

    var optionText = "Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model;
    addOption(byId("targetDisk"), diskInfo.number, optionText);
    logMessage("Disk " + diskNumber + " added as eligible target.");
    return true;
}

function enumerateDisksFromCimv2() {
    var locator = new ActiveXObject("WbemScripting.SWbemLocator");
    var service = locator.ConnectServer(".", "root\\cimv2");
    var disks = new Enumerator(service.ExecQuery("SELECT Index, Model, Size, InterfaceType, MediaType, PNPDeviceID FROM Win32_DiskDrive"));
    var rawCount = 0;
    var eligibleCount = 0;

    for (; !disks.atEnd(); disks.moveNext()) {
        var disk = disks.item();
        rawCount++;
        if (addDiskOption(disk.Index, disk.Size, disk.Model, disk.InterfaceType, disk.MediaType, disk.PNPDeviceID)) {
            eligibleCount++;
        }
    }

    logMessage("Win32_DiskDrive enumeration completed: raw=" + rawCount + ", eligible=" + eligibleCount + ".");
    return eligibleCount;
}

function refreshTargetDisks() {
    var selectObj = byId("targetDisk");
    var eligibleCount = 0;
    diskInventory = {};
    clearSelect(selectObj);
    addOption(selectObj, "", "");

    try {
        eligibleCount = enumerateDisksFromCimv2();
    } catch (e) {
        logMessage("Win32_DiskDrive enumeration failed: " + e.message);
    }

    if (eligibleCount == 0) {
        clearSelect(selectObj);
        addOption(selectObj, "", "No eligible fixed disk found");
        setStatus("No disk found by Win32_DiskDrive.");
        logMessage("No eligible fixed disk found after Win32_DiskDrive scan.");
        resetConfirmation("confirmDisk");
        return false;
    }

    if (diskInventory["0"]) {
        selectObj.value = "0";
        setStatus("Target disks refreshed. Detected target: " + diskInfoText(diskInventory["0"]));
        logMessage("Disk 0 selected automatically: " + diskInfoText(diskInventory["0"]));
    } else {
        selectObj.value = "";
        setStatus("Target disks refreshed. Disk 0 was not found. Select a target disk manually.");
        logMessage("Disk 0 was not found after refresh.");
    }
    logMessage("Target disk list refreshed. Eligible disk count=" + eligibleCount + ".");
    resetConfirmation("confirmDisk");
    updateSummary();
    return true;
}

function getSelectedDiskInfo() {
    var disk = trimText(byId("targetDisk").value);
    if (diskInventory[disk]) {
        return diskInventory[disk];
    }
    return {
        number: disk,
        sizeGb: "",
        model: ""
    };
}

function logSelectedDisk(prefix) {
    var diskInfo = getSelectedDiskInfo();
    if (diskInfo.number != "") {
        logMessage(prefix + " Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model);
    }
}

function diskInfoText(diskInfo) {
    return "Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model;
}

function startupDiskStatus(prefix) {
    if (diskInventory["0"]) {
        return prefix + " Disk 0 detected and selected.";
    }
    return prefix + " Disk 0 was not found. Select a target disk manually.";
}

function handleTargetDiskChanged() {
    resetConfirmation("confirmDisk");
    var diskInfo = getSelectedDiskInfo();
    var prefix = envLoaded ? "Target disk selected." : "DeployEnv.cmd could not be read. Deployment is disabled.";

    if (diskInfo.number != "") {
        setStatus(prefix + " Selected target: " + diskInfoText(diskInfo));
        logSelectedDisk("Target disk changed.");
    } else {
        setStatus(prefix + " Select a target disk.");
    }
    updateSummary();
}

function getEffectiveWimPath() {
    if (byId("wimPath").value == "__CUSTOM__") {
        return trimText(byId("customWimPath").value);
    }
    return trimText(byId("wimPath").value);
}

function containsApplyImageBadChars(value) {
    return /["&|<>()^!]/.test(value);
}

function isPositiveInteger(value) {
    return /^[1-9][0-9]*$/.test(trimText(value));
}

function finalConfirm() {
    var disk = trimText(byId("targetDisk").value);
    var diskInfo = getSelectedDiskInfo();
    var wimPath = getEffectiveWimPath();
    var recoverySize = trimText(byId("recoverySize").value);
    var imageIndex = trimText(byId("imageIndex").value);
    var message = "Final destructive confirmation\r\n\r\n" +
        "The tool will clean Disk " + disk + ".\r\n" +
        "Disk details: " + diskInfo.sizeGb + " | " + diskInfo.model + "\r\n" +
        "WIM path: " + wimPath + "\r\n" +
        "Image index: " + imageIndex + "\r\n" +
        "Recovery partition size: " + recoverySize + " MB\r\n\r\n" +
        "Continue?";
    return window.confirm(message);
}

function validateInputs() {
    var wimPath = getEffectiveWimPath();
    var recoverySize = trimText(byId("recoverySize").value);
    var imageIndex = trimText(byId("imageIndex").value);

    if (!isWinPE) {
        setStatus(environmentModeText() + ". Deployment is disabled outside WinPE.");
        return false;
    }
    if (wimPath == "") {
        setStatus("WIM path is required.");
        return false;
    }
    if (containsApplyImageBadChars(wimPath)) {
        setStatus("WIM path contains characters ApplyImage.bat does not accept: \" & | < > ( ) ^ !");
        return false;
    }
    if (!fso.FileExists(wimPath)) {
        setStatus("WIM file does not exist: " + wimPath);
        return false;
    }
    if (trimText(byId("targetDisk").value) == "") {
        setStatus("Target disk is required.");
        return false;
    }
    if (!diskInventory[trimText(byId("targetDisk").value)]) {
        setStatus("Target disk must be selected from the scanned fixed disk list.");
        return false;
    }
    if (recoverySize == "") {
        setStatus("Recovery partition size is required.");
        return false;
    }
    if (!isPositiveInteger(recoverySize)) {
        setStatus("Recovery partition size must be a positive integer.");
        return false;
    }
    if (parseInt(recoverySize, 10) < 1536) {
        setStatus("Recovery partition size must be at least 1536 MB.");
        return false;
    }
    if (imageIndex == "") {
        setStatus("Image index is required.");
        return false;
    }
    if (!isPositiveInteger(imageIndex)) {
        setStatus("Image index must be a positive integer.");
        return false;
    }
    return true;
}

function buildParamsText() {
    var text = "";
    text += "WIM_PATH=" + getEffectiveWimPath() + "\r\n";
    text += "TARGET_DISK=" + trimText(byId("targetDisk").value) + "\r\n";
    text += "RECOVERY_SIZE_MB=" + trimText(byId("recoverySize").value) + "\r\n";
    text += "IMAGE_INDEX=" + trimText(byId("imageIndex").value) + "\r\n";
    return text;
}

function writeParams() {
    var diskInfo = getSelectedDiskInfo();
    var text = buildParamsText();
    ensureFolder(fso.GetParentFolderName(paramsPath));
    writeTextFile(paramsPath, text);
    logMessage("Selected target disk: Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model);
    logMessage("Wrote selected_params.ini to " + paramsPath);
}

function setInputsDisabled(disabled) {
    var ids = ["wimPath", "customWimPath", "targetDisk", "recoverySize", "imageIndex", "confirmWim", "confirmDisk", "confirmRecovery"];
    for (var i = 0; i < ids.length; i++) {
        if (byId(ids[i])) {
            byId(ids[i]).disabled = disabled;
        }
    }
}

function quotePath(path) {
    return "\"" + path + "\"";
}

function runApplyImageAsync() {
    var applyPath = combinePath(deployEnv.WORKDIR, "ApplyImage.bat");
    if (!fso.FileExists(applyPath)) {
        logMessage("ApplyImage.bat not found at " + applyPath);
        setStatus("ApplyImage.bat was not found: " + applyPath);
        return false;
    }
    var command = "cmd.exe /d /v:on /c \"\"" + applyPath + "\" \"" + paramsPath + "\" & >\"" + applyRcPath + "\" echo !ERRORLEVEL!\"";
    logMessage("Starting ApplyImage.bat asynchronously.");
    shell.Run(command, 0, false);
    return true;
}

function parseKeyValueText(text) {
    var result = {};
    var lines = text.split(/\r?\n/);
    for (var i = 0; i < lines.length; i++) {
        var line = trimText(lines[i]);
        var pos = line.indexOf("=");
        if (pos > 0) {
            result[line.substring(0, pos).toUpperCase()] = line.substring(pos + 1);
        }
    }
    return result;
}

function readStateFile() {
    if (!applyStatePath || !fso.FileExists(applyStatePath)) {
        return {};
    }
    try {
        return parseKeyValueText(readTextFile(applyStatePath));
    } catch (e) {
        return {};
    }
}

function readReturnCode() {
    if (!applyRcPath || !fso.FileExists(applyRcPath)) {
        return "";
    }
    return trimText(readTextFile(applyRcPath));
}

function clampPercent(value) {
    var percent = parseInt(value, 10);
    if (isNaN(percent)) {
        percent = 0;
    }
    if (percent < 0) {
        percent = 0;
    }
    if (percent > 100) {
        percent = 100;
    }
    return percent;
}

function getLastDismPercent() {
    var text = readTail(applyLogPath, 60000);
    var re = /([0-9]{1,3}(?:\.[0-9]+)?)%/g;
    var match = null;
    var last = -1;
    while ((match = re.exec(text)) !== null) {
        var value = parseFloat(match[1]);
        if (!isNaN(value) && value >= 0 && value <= 100) {
            last = value;
        }
    }
    return last;
}

function updateProgress(percent, label, mode) {
    percent = clampPercent(percent);
    lastProgress = percent;
    byId("progressFill").style.width = percent + "%";
    byId("progressFill").className = "progress-fill" + (mode ? " " + mode : "");
    byId("progressLabel").innerText = label;
    byId("progressPercent").innerText = percent + "%";
}

function refreshLogView() {
    if (!byId("logView")) {
        return;
    }
    var text = "";
    if (htaLogPath && fso.FileExists(htaLogPath)) {
        text += "===== Deploy.hta =====\r\n" + readTail(htaLogPath, 20000);
    }
    if (applyLogPath && fso.FileExists(applyLogPath)) {
        if (text != "") {
            text += "\r\n";
        }
        text += "===== ApplyImage.bat / DISM =====\r\n" + readTail(applyLogPath, 60000);
    }
    if (diskpartLogPath && fso.FileExists(diskpartLogPath)) {
        if (text != "") {
            text += "\r\n";
        }
        text += "===== DiskPart =====\r\n" + readTail(diskpartLogPath, 30000);
    }
    if (text == "") {
        text = "Logs will appear here after DeployEnv.cmd is loaded.";
    }
    if (text != lastLogText) {
        byId("logView").value = text;
        byId("logView").scrollTop = byId("logView").scrollHeight;
        lastLogText = text;
    }
}

function resizeLogArea() {
    if (!byId("logView") || !byId("logPanel")) {
        return;
    }
    // HTA uses the IE layout engine; explicit sizing avoids textarea clipping.
    var panelHeight = byId("logPanel").clientHeight;
    var logHeight = panelHeight - 46;
    if (logHeight < 120) {
        logHeight = 120;
    }
    byId("logView").style.height = logHeight + "px";
    byId("logView").style.width = (byId("logPanel").clientWidth - 20) + "px";
}

function formatElapsed(seconds) {
    if (seconds < 0 || isNaN(seconds)) {
        seconds = 0;
    }
    var h = Math.floor(seconds / 3600);
    var m = Math.floor((seconds % 3600) / 60);
    var s = seconds % 60;
    function pad(v) {
        return (v < 10 ? "0" : "") + v;
    }
    return pad(h) + ":" + pad(m) + ":" + pad(s);
}

function updateElapsed() {
    var text = "00:00:00";
    if (deployStartTime) {
        var seconds = Math.floor((new Date().getTime() - deployStartTime.getTime()) / 1000);
        text = formatElapsed(seconds);
    }
    if (byId("summaryElapsed")) {
        byId("summaryElapsed").innerText = text;
    }
}

function startTimers() {
    if (pollTimer) {
        window.clearInterval(pollTimer);
    }
    if (elapsedTimer) {
        window.clearInterval(elapsedTimer);
    }
    pollTimer = window.setInterval("pollDeployment()", 1000);
    elapsedTimer = window.setInterval("updateElapsed()", 1000);
}

function stopTimers() {
    if (pollTimer) {
        window.clearInterval(pollTimer);
        pollTimer = null;
    }
    if (elapsedTimer) {
        window.clearInterval(elapsedTimer);
        elapsedTimer = null;
    }
}

function pollDeployment() {
    var state = readStateFile();
    var stage = state.STAGE ? state.STAGE : "RUNNING";
    var message = state.MESSAGE ? state.MESSAGE : "ApplyImage.bat is running.";
    var percent = state.PERCENT ? clampPercent(state.PERCENT) : lastProgress;
    var dismPercent = -1;
    var label = stage + " - " + message;

    if (stage == "APPLY_WIM") {
        dismPercent = getLastDismPercent();
        if (dismPercent >= 0) {
            percent = 55 + Math.round(dismPercent * 0.30);
            if (percent > 85) {
                percent = 85;
            }
            label = "APPLY_WIM - " + message + " DISM " + dismPercent + "%";
        }
    }

    updateProgress(percent, label, "");
    setStatus(label);
    refreshLogView();

    var rcText = readReturnCode();
    if (rcText != "") {
        completeDeployment(parseInt(rcText, 10));
    }
}

function completeDeployment(rc) {
    if (isNaN(rc)) {
        rc = 90;
    }
    applyRunning = false;
    stopTimers();
    refreshLogView();
    writeExitCode(rc, true);

    if (rc == 0) {
        logMessage("ApplyImage.bat completed successfully.");
        updateProgress(100, "SUCCESS - Deployment completed successfully.", "success");
        setStatus("Deployment completed successfully. Return code: 0.");
    } else {
        logMessage("ApplyImage.bat failed with return code " + rc + ".");
        updateProgress(lastProgress, "FAILED - Return code " + rc + ". Review deployment logs.", "failed");
        setStatus("Deployment failed. Return code: " + rc + ". Review deployment logs before retrying.");
    }
    byId("closeButton").style.display = "inline-block";
}

function startDeployment() {
    var rc = 30;
    try {
        if (!isWinPE) {
            logMessage("Deployment start blocked: " + environmentModeText() + ".");
            setStatus(environmentModeText() + ". Deployment is disabled outside WinPE.");
            writeExitCode(30, true);
            updateDeployState();
            return;
        }
        if (!envLoaded) {
            setStatus("DeployEnv.cmd is not available. Deployment cannot start.");
            writeExitCode(30, true);
            return;
        }
        if (!byId("confirmWim").checked || !byId("confirmDisk").checked || !byId("confirmRecovery").checked) {
            setStatus("Confirm all deployment parameters before starting.");
            updateDeployState();
            return;
        }
        if (!validateInputs()) {
            return;
        }
        if (!finalConfirm()) {
            logMessage("Operator cancelled final confirmation.");
            writeExitCode(10, false);
            setStatus("Deployment cancelled before parameters were written.");
            window.close();
            return;
        }

        ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta"));
        ensureFolder(applyDetailPath);
        deleteFileIfExists(applyStatePath);
        deleteFileIfExists(applyRcPath);
        logMessage("Deployment confirmed by operator.");
        writeParams();

        deploymentStarted = true;
        applyRunning = true;
        deployStartTime = new Date();
        setInputsDisabled(true);
        byId("deployButton").disabled = true;
        byId("cancelButton").disabled = true;
        byId("closeButton").style.display = "none";
        writeExitCode(90, true);
        updateProgress(3, "STARTING - Launching ApplyImage.bat.", "");
        setStatus("Deployment is running. Do not close this window.");
        refreshLogView();

        if (!runApplyImageAsync()) {
            rc = 30;
            writeTextFile(applyRcPath, String(rc) + "\r\n");
            completeDeployment(rc);
            return;
        }

        startTimers();
        pollDeployment();
    } catch (e) {
        logMessage("HTA error: " + e.message);
        if (!deploymentStarted) {
            rc = 30;
        } else {
            rc = 90;
        }
        writeExitCode(rc, true);
        updateProgress(lastProgress, "FAILED - HTA error.", "failed");
        setStatus("Deployment UI failed. Return code: " + rc + ". Error: " + e.message);
        byId("closeButton").style.display = "inline-block";
    }
}

function cancelDeployment() {
    if (deploymentStarted) {
        return;
    }
    writeExitCode(10, false);
    logMessage("Operator cancelled deployment.");
    window.close();
}

function shutdownComputer() {
    if (!window.confirm("Shutdown this computer now?")) {
        return;
    }
    logMessage("Operator requested shutdown.");
    try {
        shell.Run("wpeutil shutdown", 0, false);
    } catch (e) {
        shell.Run("shutdown.exe /s /t 0", 0, false);
    }
}

function openCommandLine() {
    logMessage("Operator opened command line.");
    shell.Run("cmd.exe", 1, false);
}

function init() {
    DetectEnvironment();
    updateEnvironmentModeInfo();
    clearSelect(byId("wimPath"));
    addOption(byId("wimPath"), "", "Waiting for mapped drive scan...");
    byId("wimPath").disabled = true;
    byId("customWimPath").value = "";
    byId("customWimPath").disabled = true;
    byId("recoverySize").value = "1536";
    byId("imageIndex").value = "1";
    updateProgress(0, "READY - Waiting for deployment parameters.", "");

    try {
        envLoaded = readDeployEnv();
    } catch (e) {
        envLoaded = false;
        var envReadError = e.message;
        try {
            htaDir = getHtaDirectory();
            inferFallbackEnv();
            preparePaths();
            writeExitCode(30, true);
            logMessage("DeployEnv.cmd read failed: " + envReadError);
        } catch (inner) {
            setStatus("DeployEnv.cmd could not be read. Deployment is disabled.");
            updateSummary();
            updateDeployState();
            return;
        }
    }
    if (!envLoaded) {
        writeExitCode(30, true);
        try {
            refreshTargetDisks();
            setStatus(startupDiskStatus("DeployEnv.cmd could not be read. Deployment is disabled."));
        } catch (diskError) {
            setStatus("DeployEnv.cmd could not be read. Deployment is disabled. Disk scan failed: " + diskError.message);
            logMessage("Startup disk scan failed: " + diskError.message);
        }
    } else {
        try {
            ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta"));
            ensureFolder(applyDetailPath);
            logMessage("Deploy.hta initialized. RUNID=" + (deployEnv.RUNID ? deployEnv.RUNID : ""));
            logMessage("Detected environment: " + environmentModeText() + ".");
            var mappedWimFound = detectMappedInstallWim();
            if (refreshTargetDisks()) {
                if (isWinPE) {
                    setStatus(startupDiskStatus(mappedWimFound ? "Ready. WIM auto-detected." : "Ready. Enter custom WIM path."));
                } else {
                    setStatus(environmentModeText() + ". Deployment is disabled outside WinPE.");
                }
            }
        } catch (e) {
            envLoaded = false;
            setStatus("Log directory could not be prepared. Deployment is disabled. " + e.message);
            writeExitCode(30, true);
        }
    }
    setEnvironmentInfo();
    updateSummary();
    resizeLogArea();
    refreshLogView();
    updateDeployState();
}
</script>
</head>
<body onload="init()" onresize="resizeLogArea()" onunload="handleWindowUnload()">
<div class="app">
    <!-- Top layer: parameter input on the left, operator summary/actions on the right. -->
    <div class="top-layer">
        <div class="panel left-panel">
            <div class="title-row">
                <h1>WinOS Deployment Tool</h1>
                <div class="mode mode-safe"><span id="modeValue">Environment: Detecting...</span></div>
                <div class="subtle">RunID: <span id="runIdValue">(not loaded)</span></div>
                <div class="subtle">LOGDIR: <span id="logDirValue">(not loaded)</span></div>
            </div>

            <div class="pair">
                <div class="cell">
                    <div class="row">
                        <label for="wimPath">Target WIM file</label>
                        <select id="wimPath" onchange="updateWimCustomState()">
                            <option value="">Waiting for mapped drive scan...</option>
                        </select>
                    </div>
                </div>
                <div class="cell">
                    <div class="row">
                        <label for="customWimPath">Custom WIM file</label>
                        <input class="text" type="text" id="customWimPath" onchange="resetConfirmation('confirmWim')" onkeyup="resetConfirmation('confirmWim')" />
                    </div>
                </div>
            </div>

            <div class="pair">
                <div class="cell">
                    <div class="row">
                        <label for="targetDisk">Target disk</label>
                        <select id="targetDisk" onchange="handleTargetDiskChanged()">
                            <option value="">Scanning local disks...</option>
                        </select>
                    </div>
                </div>
                <div class="cell">
                    <div class="row">
                        <label for="recoverySize">Recovery partition</label>
                        <select id="recoverySize" onchange="resetConfirmation('confirmRecovery')">
                            <option value="1536">1536 MB</option>
                            <option value="2048">2048 MB</option>
                            <option value="3072">3072 MB</option>
                            <option value="4096">4096 MB</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <label for="imageIndex">Image index</label>
                <input class="text" type="text" id="imageIndex" onchange="resetConfirmation('confirmWim')" onkeyup="resetConfirmation('confirmWim')" />
            </div>

        </div>

        <div class="panel right-panel">
            <!-- Deployment summary mirrors the effective parameters without exposing raw INI text. -->
            <div class="section-title">Deployment summary</div>
            <div class="summary">
                <div class="summary-row">
                    <div class="summary-name">Target WIM file</div>
                    <div class="summary-value" id="summaryWim">(not selected)</div>
                </div>
                <div class="summary-row">
                    <div class="summary-name">Target disk</div>
                    <div class="summary-value" id="summaryDisk">(not selected)</div>
                </div>
                <div class="summary-row">
                    <div class="summary-name">Recovery size</div>
                    <div class="summary-value" id="summaryRecovery">(not selected)</div>
                </div>
                <div class="summary-row">
                    <div class="summary-name">Elapsed</div>
                    <div class="summary-value" id="summaryElapsed">00:00:00</div>
                </div>
            </div>

            <div class="checks">
                <div class="section-title danger">Required confirmations</div>
                <label><input type="checkbox" id="confirmWim" onclick="updateDeployState()" /> WIM path confirmed</label>
                <label><input type="checkbox" id="confirmDisk" onclick="updateDeployState()" /> Target disk clean confirmed</label>
                <label><input type="checkbox" id="confirmRecovery" onclick="updateDeployState()" /> Recovery partition size confirmed</label>
            </div>

            <div class="button-row">
                <button id="commandButton" onclick="openCommandLine()">Command Line</button>
                <button id="shutdownButton" onclick="shutdownComputer()">Shutdown</button>
                <button id="cancelButton" onclick="cancelDeployment()">Cancel</button>
                <button id="deployButton" class="primary" onclick="startDeployment()" disabled>Start Apply</button>
                <button id="closeButton" onclick="window.close()" style="display:none">Close</button>
            </div>
        </div>
    </div>

    <!-- Middle layer: stage progress plus DISM percentage when Apply-Image is running. -->
    <div class="panel middle-layer">
        <div class="progress-header">
            <div class="progress-label" id="progressLabel">READY</div>
            <div class="progress-percent" id="progressPercent">0%</div>
        </div>
        <div class="progress-track">
            <div id="progressFill" class="progress-fill"></div>
        </div>
        <div id="statusBox">Initializing...</div>
    </div>

    <!-- Bottom layer: live combined HTA, ApplyImage, DISM, and DiskPart logs. -->
    <div class="panel bottom-layer" id="logPanel">
        <div class="section-title">Detailed deployment log</div>
        <textarea id="logView" class="codebox log-box" readonly></textarea>
    </div>
</div>
</body>
</html>

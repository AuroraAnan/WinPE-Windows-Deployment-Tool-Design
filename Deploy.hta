<!DOCTYPE html>
<html>
<head>
<title>WinPE Deployment Tool</title>
<HTA:APPLICATION
    ID="WinPEDeploymentTool"
    APPLICATIONNAME="WinPEDeploymentTool"
    BORDER="none"
    CAPTION="yes"
    CONTEXTMENU="no"
    WINDOWSTATE="maximize"
    RESIZABLE="no"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
>
<meta http-equiv="X-UA-Compatible" content="IE=9">
<style type="text/css">
body {
    margin: 0;
    background: #f3f5f8;
    color: #1f2933;
    font-family: Segoe UI, Arial, sans-serif;
    font-size: 13px;
}
.wrap {
    width: 760px;
    margin: 0 auto;
    padding: 18px;
}
.header {
    border-bottom: 1px solid #c7d0da;
    padding-bottom: 12px;
    margin-bottom: 16px;
}
h1 {
    margin: 0 0 4px 0;
    font-size: 22px;
    font-weight: 600;
}
.subtle {
    color: #52616f;
}
.panel {
    background: #ffffff;
    border: 1px solid #c7d0da;
    padding: 14px;
    margin-bottom: 14px;
}
.row {
    margin-bottom: 12px;
}
label {
    display: block;
    font-weight: 600;
    margin-bottom: 4px;
}
input.text {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #a7b2be;
    padding: 7px;
    font-family: Consolas, Courier New, monospace;
    font-size: 13px;
}
select {
    width: 220px;
    border: 1px solid #a7b2be;
    padding: 6px;
    font-size: 13px;
}
select.wide {
    width: 100%;
}
.checks label {
    font-weight: 400;
    margin: 7px 0;
}
.buttons {
    text-align: right;
    padding-top: 6px;
}
button {
    min-width: 118px;
    padding: 8px 12px;
    border: 1px solid #7c8794;
    background: #e8edf3;
    color: #1f2933;
    font-weight: 600;
    cursor: pointer;
}
button.primary {
    background: #155b9f;
    border-color: #124d86;
    color: #ffffff;
}
button:disabled {
    background: #d7dde5;
    border-color: #bac3cc;
    color: #7a8591;
    cursor: default;
}
#statusBox {
    min-height: 42px;
    border: 1px solid #c7d0da;
    background: #f8fafc;
    padding: 10px;
    white-space: pre-wrap;
}
.danger {
    color: #9a3412;
    font-weight: 600;
}
.envline {
    font-family: Consolas, Courier New, monospace;
    overflow-wrap: break-word;
}
</style>
<script language="JScript" type="text/javascript">
var fso = new ActiveXObject("Scripting.FileSystemObject");
var shell = new ActiveXObject("WScript.Shell");
var deployEnv = {};
var envLoaded = false;
var htaDir = "";
var htaLogPath = "";
var paramsPath = "";
var exitCodePath = "";
var exitCodeWritten = false;
var deploymentStarted = false;
var diskInventory = {};

function byId(id) {
    return document.getElementById(id);
}

function setStatus(message) {
    byId("statusBox").innerText = message;
}

function getHtaDirectory() {
    var path = unescape(location.pathname);
    path = path.replace(/\//g, "\\");
    if (path.charAt(0) == "\\" && path.charAt(2) == ":") {
        path = path.substring(1);
    }
    return fso.GetParentFolderName(path);
}

function trimText(value) {
    if (value === null || value === undefined) {
        return "";
    }
    return String(value).replace(/^\s+|\s+$/g, "");
}

function combinePath(left, right) {
    if (left.charAt(left.length - 1) == "\\") {
        return left + right;
    }
    return left + "\\" + right;
}

function ensureFolder(path) {
    if (!path || fso.FolderExists(path)) {
        return;
    }
    var parent = fso.GetParentFolderName(path);
    if (parent && parent != path && !fso.FolderExists(parent)) {
        ensureFolder(parent);
    }
    if (!fso.FolderExists(path)) {
        fso.CreateFolder(path);
    }
}

function writeTextFile(path, text) {
    var file = fso.CreateTextFile(path, true);
    file.Write(text);
    file.Close();
}

function appendTextFile(path, text) {
    var file = fso.OpenTextFile(path, 8, true);
    file.Write(text);
    file.Close();
}

function nowText() {
    var d = new Date();
    function pad(v) {
        return (v < 10 ? "0" : "") + v;
    }
    return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate()) +
        " " + pad(d.getHours()) + ":" + pad(d.getMinutes()) + ":" + pad(d.getSeconds());
}

function logMessage(message) {
    var line = nowText() + " " + message + "\r\n";
    try {
        if (htaLogPath) {
            appendTextFile(htaLogPath, line);
        }
        if (deployEnv.SESSION_LOG) {
            appendTextFile(deployEnv.SESSION_LOG, "[10] " + line);
        }
    } catch (e) {
    }
}

function parseEnvLine(line) {
    var text = trimText(line);
    var match = /^set\s+"([^=]+)=(.*)"$/i.exec(text);
    if (match) {
        deployEnv[match[1].toUpperCase()] = match[2];
    }
}

function readEnvFile(path) {
    if (!fso.FileExists(path)) {
        return false;
    }
    var file = fso.OpenTextFile(path, 1, false);
    while (!file.AtEndOfStream) {
        parseEnvLine(file.ReadLine());
    }
    file.Close();
    return true;
}

function inferFallbackEnv() {
    var tempRoot = shell.ExpandEnvironmentStrings("%TEMP%");
    deployEnv.WORKDIR = htaDir;
    deployEnv.LOGDIR = combinePath(tempRoot, "AutoApply\\LOG\\UNKNOWN_HTA_ENV");
}

function preparePaths() {
    var htaDetail = combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta");
    htaLogPath = combinePath(htaDetail, "deploy_hta.log");
    paramsPath = combinePath(htaDetail, "selected_params.ini");
    exitCodePath = combinePath(htaDetail, "hta_exit_code.txt");
}

function setEnvironmentInfo() {
    if (!byId("runIdValue") || !byId("logDirValue")) {
        return;
    }
    byId("runIdValue").innerText = deployEnv.RUNID ? deployEnv.RUNID : "(not loaded)";
    byId("logDirValue").innerText = deployEnv.LOGDIR ? deployEnv.LOGDIR : "(not loaded)";
}

function readDeployEnv() {
    htaDir = getHtaDirectory();
    var envPath = combinePath(htaDir, "DeployEnv.cmd");
    var currentEnvPath = fso.GetAbsolutePathName("DeployEnv.cmd");
    deployEnv = {};
    setEnvironmentInfo();

    if (!readEnvFile(envPath) && !readEnvFile(currentEnvPath)) {
        inferFallbackEnv();
        preparePaths();
        setEnvironmentInfo();
        return false;
    }

    if (!deployEnv.WORKDIR) {
        deployEnv.WORKDIR = htaDir;
    }
    if (!deployEnv.LOGDIR) {
        inferFallbackEnv();
        preparePaths();
        setEnvironmentInfo();
        return false;
    }
    preparePaths();
    setEnvironmentInfo();
    return true;
}

function writeExitCode(code, forceOverwrite) {
    if (exitCodeWritten && forceOverwrite !== true) {
        return true;
    }
    try {
        if (!exitCodePath) {
            preparePaths();
        }
        ensureFolder(fso.GetParentFolderName(exitCodePath));
        writeTextFile(exitCodePath, String(code) + "\r\n");
        exitCodeWritten = true;
        return true;
    } catch (e) {
        return false;
    }
}

function handleWindowUnload() {
    if (!exitCodeWritten && !deploymentStarted) {
        writeExitCode(10, false);
    }
}

function updateDeployState() {
    var disk = trimText(byId("targetDisk").value);

    var ready = envLoaded &&
        disk != "" &&
        diskInventory[disk] &&
        byId("confirmWim").checked &&
        byId("confirmDisk").checked &&
        byId("confirmRecovery").checked;
    byId("deployButton").disabled = !ready;
}

function resetConfirmation(confirmId) {
    byId(confirmId).checked = false;
    updateDeployState();
}

function updateWimCustomState() {
    byId("customWimPath").disabled = byId("wimPath").value != "__CUSTOM__";
    resetConfirmation("confirmWim");
}

function clearSelect(selectObj) {
    while (selectObj.options.length > 0) {
        selectObj.remove(0);
    }
}

function addOption(selectObj, value, text) {
    var option = document.createElement("option");
    option.value = value;
    option.text = text;
    selectObj.add(option);
    return option;
}

function bytesToGbText(sizeValue) {
    var bytes = parseFloat(sizeValue);
    if (isNaN(bytes) || bytes <= 0) {
        return "UnknownGB";
    }
    return Math.round(bytes / 1073741824) + "GB";
}

function normalizeBusType(value) {
    var text = trimText(value);
    var busMap = {
        "0": "Unknown",
        "1": "SCSI",
        "2": "ATAPI",
        "3": "ATA",
        "4": "IEEE1394",
        "5": "SSA",
        "6": "Fibre Channel",
        "7": "USB",
        "8": "RAID",
        "9": "iSCSI",
        "10": "SAS",
        "11": "SATA",
        "12": "SD",
        "13": "MMC",
        "14": "Virtual",
        "15": "File Backed Virtual",
        "16": "Storage Spaces",
        "17": "NVMe"
    };
    if (busMap[text]) {
        return busMap[text];
    }
    return text == "" ? "Unknown" : text;
}

function isExcludedDisk(busType, mediaType, model) {
    var bus = normalizeBusType(busType).toUpperCase();
    var media = trimText(mediaType).toUpperCase();
    var diskModel = trimText(model).toUpperCase();
    if (bus == "USB" || bus == "SD" || bus == "MMC" || bus == "IEEE1394") {
        return true;
    }
    if (media.indexOf("REMOVABLE") >= 0) {
        return true;
    }
    if (diskModel.indexOf(" USB ") >= 0 || diskModel.indexOf("USB DISK") >= 0) {
        return true;
    }
    return false;
}

function addDiskOption(index, sizeBytes, model, busType, mediaType) {
    var diskNumber = trimText(index);
    if (diskNumber == "" || isExcludedDisk(busType, mediaType, model)) {
        return;
    }

    var diskInfo = {
        number: diskNumber,
        sizeGb: bytesToGbText(sizeBytes),
        model: trimText(model) == "" ? "Unknown model" : trimText(model),
        busType: normalizeBusType(busType),
        mediaType: trimText(mediaType)
    };
    diskInventory[diskNumber] = diskInfo;

    var optionText = "Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model + " | " + diskInfo.busType;
    addOption(byId("targetDisk"), diskInfo.number, optionText);
}

function enumerateDisksFromStorageWmi() {
    var service = GetObject("winmgmts:{impersonationLevel=impersonate}!\\\\.\\root\\microsoft\\windows\\storage");
    var disks = new Enumerator(service.ExecQuery("SELECT Number, FriendlyName, Size, BusType, MediaType FROM MSFT_Disk"));
    var count = 0;
    for (; !disks.atEnd(); disks.moveNext()) {
        var disk = disks.item();
        addDiskOption(disk.Number, disk.Size, disk.FriendlyName, disk.BusType, disk.MediaType);
        count++;
    }
    return count;
}

function enumerateDisksFromCimv2() {
    var service = GetObject("winmgmts:{impersonationLevel=impersonate}!\\\\.\\root\\cimv2");
    var disks = new Enumerator(service.ExecQuery("SELECT Index, Model, Size, InterfaceType, MediaType FROM Win32_DiskDrive"));
    var count = 0;
    for (; !disks.atEnd(); disks.moveNext()) {
        var disk = disks.item();
        addDiskOption(disk.Index, disk.Size, disk.Model, disk.InterfaceType, disk.MediaType);
        count++;
    }
    return count;
}

function refreshTargetDisks() {
    var selectObj = byId("targetDisk");
    diskInventory = {};
    clearSelect(selectObj);

    try {
        enumerateDisksFromStorageWmi();
    } catch (e) {
        logMessage("MSFT_Disk enumeration failed: " + e.message);
    }

    if (selectObj.options.length == 0) {
        try {
            enumerateDisksFromCimv2();
        } catch (fallbackError) {
            logMessage("Win32_DiskDrive enumeration failed: " + fallbackError.message);
        }
    }

    if (selectObj.options.length == 0) {
        addOption(selectObj, "", "No eligible fixed disk found");
        setStatus("No eligible fixed disk found. USB/removable devices are excluded.");
        logMessage("No eligible fixed disk found after disk scan.");
        resetConfirmation("confirmDisk");
        return false;
    } else {
        selectObj.value = diskInventory["0"] ? "0" : selectObj.options[0].value;
        logSelectedDisk("Target disk list refreshed.");
    }
    resetConfirmation("confirmDisk");
    return true;
}

function getSelectedDiskInfo() {
    var disk = trimText(byId("targetDisk").value);
    if (diskInventory[disk]) {
        return diskInventory[disk];
    }
    return {
        number: disk,
        sizeGb: "",
        model: "",
        busType: "",
        mediaType: ""
    };
}

function logSelectedDisk(prefix) {
    var diskInfo = getSelectedDiskInfo();
    if (diskInfo.number != "") {
        logMessage(prefix + " Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model + " | " + diskInfo.busType);
    }
}

function getEffectiveWimPath() {
    if (byId("wimPath").value == "__CUSTOM__") {
        return trimText(byId("customWimPath").value);
    }
    return trimText(byId("wimPath").value);
}

function containsApplyImageBadChars(value) {
    return /["&|<>()^!]/.test(value);
}

function isPositiveInteger(value) {
    return /^[1-9][0-9]*$/.test(trimText(value));
}

function finalConfirm() {
    var disk = trimText(byId("targetDisk").value);
    var diskInfo = getSelectedDiskInfo();
    var wimPath = getEffectiveWimPath();
    var recoverySize = trimText(byId("recoverySize").value);
    var imageIndex = trimText(byId("imageIndex").value);
    var message = "Final destructive confirmation\r\n\r\n" +
        "The tool will clean Disk " + disk + ".\r\n" +
        "Disk details: " + diskInfo.sizeGb + " | " + diskInfo.model + " | " + diskInfo.busType + "\r\n" +
        "WIM path: " + wimPath + "\r\n" +
        "Image index: " + imageIndex + "\r\n" +
        "Recovery partition size: " + recoverySize + " MB\r\n\r\n" +
        "Continue?";
    return window.confirm(message);
}

function validateInputs() {
    var wimPath = getEffectiveWimPath();
    var recoverySize = trimText(byId("recoverySize").value);
    var imageIndex = trimText(byId("imageIndex").value);

    if (wimPath == "") {
        setStatus("WIM path is required.");
        return false;
    }
    if (containsApplyImageBadChars(wimPath)) {
        setStatus("WIM path contains characters ApplyImage.bat does not accept: \" & | < > ( ) ^ !");
        return false;
    }
    if (!fso.FileExists(wimPath)) {
        setStatus("WIM file does not exist:\r\n" + wimPath);
        return false;
    }
    if (trimText(byId("targetDisk").value) == "") {
        setStatus("Target disk is required.");
        return false;
    }
    if (!diskInventory[trimText(byId("targetDisk").value)]) {
        setStatus("Target disk must be selected from the scanned fixed disk list.");
        return false;
    }
    if (recoverySize == "") {
        setStatus("Recovery partition size is required.");
        return false;
    }
    if (!isPositiveInteger(recoverySize)) {
        setStatus("Recovery partition size must be a positive integer.");
        return false;
    }
    if (parseInt(recoverySize, 10) < 1536) {
        setStatus("Recovery partition size must be at least 1536 MB.");
        return false;
    }
    if (imageIndex == "") {
        setStatus("Image index is required.");
        return false;
    }
    if (!isPositiveInteger(imageIndex)) {
        setStatus("Image index must be a positive integer.");
        return false;
    }
    return true;
}

function writeParams() {
    var diskInfo = getSelectedDiskInfo();
    var text = "";
    text += "WIM_PATH=" + getEffectiveWimPath() + "\r\n";
    text += "TARGET_DISK=" + trimText(byId("targetDisk").value) + "\r\n";
    text += "RECOVERY_SIZE_MB=" + trimText(byId("recoverySize").value) + "\r\n";
    text += "IMAGE_INDEX=" + trimText(byId("imageIndex").value) + "\r\n";
    writeTextFile(paramsPath, text);
    logMessage("Selected target disk: Disk " + diskInfo.number + " | " + diskInfo.sizeGb + " | " + diskInfo.model + " | " + diskInfo.busType);
    logMessage("Wrote selected_params.ini to " + paramsPath);
}

function quotePath(path) {
    return "\"" + path + "\"";
}

function runApplyImage() {
    var applyPath = combinePath(deployEnv.WORKDIR, "ApplyImage.bat");
    if (!fso.FileExists(applyPath)) {
        logMessage("ApplyImage.bat not found at " + applyPath);
        setStatus("ApplyImage.bat was not found:\r\n" + applyPath);
        return 30;
    }
    var command = "cmd.exe /d /c " + quotePath(quotePath(applyPath) + " " + quotePath(paramsPath));
    logMessage("Running ApplyImage.bat.");
    return shell.Run(command, 1, true);
}

function startDeployment() {
    var rc = 30;
    try {
        if (!envLoaded) {
            setStatus("DeployEnv.cmd is not available. Deployment cannot start.");
            writeExitCode(30, true);
            return;
        }
        if (!byId("confirmWim").checked || !byId("confirmDisk").checked || !byId("confirmRecovery").checked) {
            setStatus("Confirm all deployment parameters before starting.");
            updateDeployState();
            return;
        }
        if (!validateInputs()) {
            return;
        }
        if (!finalConfirm()) {
            logMessage("Operator cancelled final confirmation.");
            writeExitCode(10, false);
            setStatus("Deployment cancelled before parameters were written.");
            window.close();
            return;
        }

        ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta"));
        ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "20_applyimage"));
        logMessage("Deployment confirmed by operator.");
        writeParams();
        setStatus("Deployment is running. Do not close this window.");
        byId("deployButton").disabled = true;
        byId("cancelButton").disabled = true;

        writeExitCode(90, true);
        deploymentStarted = true;
        rc = 90;
        rc = runApplyImage();
        writeExitCode(rc, true);

        if (rc == 0) {
            logMessage("ApplyImage.bat completed successfully.");
            setStatus("Deployment completed successfully.\r\nReturn code: 0\r\nClose this window to continue.");
        } else {
            logMessage("ApplyImage.bat failed with return code " + rc + ".");
            setStatus("Deployment failed.\r\nReturn code: " + rc + "\r\nReview deployment logs before retrying.");
        }
        byId("closeButton").style.display = "inline-block";
    } catch (e) {
        logMessage("HTA error: " + e.message);
        if (!deploymentStarted) {
            rc = 30;
        }
        writeExitCode(rc, true);
        setStatus("Deployment UI failed.\r\nReturn code: " + rc + "\r\nError: " + e.message);
        byId("closeButton").style.display = "inline-block";
    }
}

function cancelDeployment() {
    writeExitCode(10, false);
    logMessage("Operator cancelled deployment.");
    window.close();
}

function init() {
    byId("wimPath").value = "Z:\\Images\\Install.wim";
    byId("customWimPath").value = "";
    updateWimCustomState();
    byId("recoverySize").value = "1536";
    byId("imageIndex").value = "1";

    try {
        envLoaded = readDeployEnv();
    } catch (e) {
        envLoaded = false;
        try {
            htaDir = getHtaDirectory();
            inferFallbackEnv();
            preparePaths();
            setStatus("DeployEnv.cmd could not be read. Deployment is disabled.\r\n" + e.message);
            writeExitCode(30, true);
            logMessage("DeployEnv.cmd read failed: " + e.message);
        } catch (inner) {
            setStatus("DeployEnv.cmd could not be read. Deployment is disabled.");
        }
        updateDeployState();
        return;
    }
    if (!envLoaded) {
        setStatus("DeployEnv.cmd could not be read. Deployment is disabled.");
        writeExitCode(30, true);
    } else {
        try {
            ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "10_deploy_hta"));
            ensureFolder(combinePath(combinePath(deployEnv.LOGDIR, "details"), "20_applyimage"));
            logMessage("Deploy.hta initialized. RUNID=" + (deployEnv.RUNID ? deployEnv.RUNID : ""));
            if (refreshTargetDisks()) {
                setStatus("Ready. Review settings and complete all confirmations.");
            }
        } catch (e) {
            envLoaded = false;
            setStatus("Log directory could not be prepared. Deployment is disabled.\r\n" + e.message);
            writeExitCode(30, true);
        }
    }
    updateDeployState();
}
</script>
</head>
<body onload="init()" onunload="handleWindowUnload()">
<div class="wrap">
    <div class="header">
        <h1>WinPE Deployment Tool</h1>
        <div class="subtle">Review deployment inputs before applying the image.</div>
    </div>

    <div class="panel">
        <div class="row">
            <label>RUNID</label>
            <div class="envline" id="runIdValue">(not loaded)</div>
        </div>
        <div class="row">
            <label>LOGDIR</label>
            <div class="envline" id="logDirValue">(not loaded)</div>
        </div>
    </div>

    <div class="panel">
        <div class="row">
            <label for="wimPath">WIM path</label>
            <select class="wide" id="wimPath" onchange="updateWimCustomState()">
                <option value="Z:\Images\Install.wim">Z:\Images\Install.wim</option>
                <option value="Z:\Images\install.wim">Z:\Images\install.wim</option>
                <option value="__CUSTOM__">Other/custom path</option>
            </select>
        </div>
        <div class="row">
            <label for="customWimPath">Custom WIM path</label>
            <input class="text" type="text" id="customWimPath" onchange="resetConfirmation('confirmWim')" onkeyup="resetConfirmation('confirmWim')" />
        </div>
        <div class="row">
            <label for="targetDisk">Target disk</label>
            <select class="wide" id="targetDisk" onchange="resetConfirmation('confirmDisk'); logSelectedDisk('Target disk changed.')">
                <option value="">Scanning local disks...</option>
            </select>
        </div>
        <div class="row">
            <label for="recoverySize">Recovery partition size (MB)</label>
            <select id="recoverySize" onchange="resetConfirmation('confirmRecovery')">
                <option value="1536">1536 MB</option>
                <option value="2048">2048 MB</option>
                <option value="3072">3072 MB</option>
                <option value="4096">4096 MB</option>
            </select>
        </div>
        <div class="row">
            <label for="imageIndex">Image index</label>
            <input class="text" type="text" id="imageIndex" onchange="resetConfirmation('confirmWim')" onkeyup="resetConfirmation('confirmWim')" />
        </div>
    </div>

    <div class="panel checks">
        <div class="danger">Required confirmations</div>
        <label><input type="checkbox" id="confirmWim" onclick="updateDeployState()" /> I confirmed this WIM path.</label>
        <label><input type="checkbox" id="confirmDisk" onclick="updateDeployState()" /> I confirmed this disk will be cleaned.</label>
        <label><input type="checkbox" id="confirmRecovery" onclick="updateDeployState()" /> I confirmed this recovery partition size.</label>
    </div>

    <div class="panel">
        <label>Status</label>
        <div id="statusBox">Initializing...</div>
        <div class="buttons">
            <button id="cancelButton" onclick="cancelDeployment()">Cancel</button>
            <button id="deployButton" class="primary" onclick="startDeployment()" disabled>Deploy</button>
            <button id="closeButton" onclick="window.close()" style="display:none">Close</button>
        </div>
    </div>
</div>
</body>
</html>
